# Copy this file to `.env` and fill in your values.
# Get a key from https://aistudio.google.com/apikey

# Required: Google Gemini API key
GEMINI_API_KEY=your-google-ai-studio-api-key

# Model + determinism controls (defaults are tuned for reproducible, rule-bound triage)
SERENA_MODEL=gemini-2.5-flash
SERENA_TEMPERATURE=0.0
SERENA_TOP_P=0.1
SERENA_MAX_OUTPUT_TOKENS=2048

# CORS — comma-separated list of allowed frontend origins (Lovable preview + local dev)
SERENA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
